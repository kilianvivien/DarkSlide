{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "scanning-session",
  "description": "permissions for the scanning session window",
  "windows": [
    "scanning"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "dialog:default"
  ]
}
