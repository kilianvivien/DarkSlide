{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:menu:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "fs:default",
    "fs:allow-stat",
    "fs:allow-read-text-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "opener:default"
  ]
}
